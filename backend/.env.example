NODE_ENV=development
PORT=3000
LOG_LEVEL=info

MONGODB_URI=mongodb://localhost:27017/pocketvoice

JWT_ACCESS_SECRET=change-me-to-256-bit-random
JWT_REFRESH_SECRET=change-me-to-another-256-bit-random
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=60d
BCRYPT_ROUNDS=12

GROQ_API_KEY=gsk_your_key_here
GROQ_PRIMARY_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama-3.1-8b-instant
POLISH_PRIMARY_TIMEOUT_MS=2500
POLISH_FALLBACK_TIMEOUT_MS=1500

POLISH_CACHE_MAX=1000
POLISH_CACHE_TTL_MS=3600000

GOOGLE_OAUTH_IOS_CLIENT_ID=your-client-id-here
