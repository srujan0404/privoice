{
  "info": {
    "name": "PocketVoice Backend",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
      }
    },
    {
      "name": "Register",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth","register"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"a@b.com\",\n  \"password\": \"password123\",\n  \"displayName\": \"Asha\"\n}" }
      }
    },
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth","login"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"email\": \"a@b.com\",\n  \"password\": \"password123\"\n}" }
      }
    },
    {
      "name": "Refresh",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/auth/refresh", "host": ["{{baseUrl}}"], "path": ["auth","refresh"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/auth/logout", "host": ["{{baseUrl}}"], "path": ["auth","logout"] },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
      }
    },
    {
      "name": "Me (GET)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/me", "host": ["{{baseUrl}}"], "path": ["me"] },
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
      }
    },
    {
      "name": "Me (PATCH)",
      "request": {
        "method": "PATCH",
        "url": { "raw": "{{baseUrl}}/me", "host": ["{{baseUrl}}"], "path": ["me"] },
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"displayName\": \"Renamed\"\n}" }
      }
    },
    {
      "name": "Sync Pull",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/sync", "host": ["{{baseUrl}}"], "path": ["sync"] },
        "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }]
      }
    },
    {
      "name": "Sync Push",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/sync", "host": ["{{baseUrl}}"], "path": ["sync"] },
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"notes\": [],\n  \"messages\": [],\n  \"snippets\": [],\n  \"vocab\": [],\n  \"toneSettings\": null\n}" }
      }
    },
    {
      "name": "Polish",
      "request": {
        "method": "POST",
        "url": { "raw": "{{baseUrl}}/polish", "host": ["{{baseUrl}}"], "path": ["polish"] },
        "header": [
          { "key": "Authorization", "value": "Bearer {{accessToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"transcript\": \"hey um so i wanted to follow up\",\n  \"tone\": \"professional\",\n  \"appName\": \"Gmail\"\n}" }
      }
    }
  ]
}
